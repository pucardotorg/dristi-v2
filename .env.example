# Copy to .env.local and fill in values
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"

# ── App ──
NEXT_PUBLIC_PERSIST_DRAFT=true
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth (Better Auth) ──
BETTER_AUTH_SECRET=<generate-random-secret>
BETTER_AUTH_URL=http://localhost:3000
ALLOW_SEED=true  # set to create demo user via /api/auth/seed, remove after

# ── Database (PostgreSQL) ──
# Local:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pucar
# Neon (pooled):
# DATABASE_URL=postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require

# ── S3-compatible storage ──
# Local (MinIO via docker compose up -d):
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=pucar-docs
S3_REGION=auto
# Cloudflare R2:
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=<r2-access-key>
# S3_SECRET_ACCESS_KEY=<r2-secret-key>
# S3_BUCKET=pucar-docs
# S3_REGION=auto
